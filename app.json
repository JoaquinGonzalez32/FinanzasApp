    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "40b0996a-ff6f-4322-8a90-246fcc68abc4"
      }
    },
    "owner": "joaquingonzalezexpo",
